<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.Cursor?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.Separator?>
<?import javafx.scene.effect.DropShadow?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.paint.Color?>
<?import javafx.scene.text.Font?>

<BorderPane prefHeight="800.0" prefWidth="1200.0" style="-fx-background-color: #F4F7FE;" xmlns="http://javafx.com/javafx/25" xmlns:fx="http://javafx.com/fxml/1" fx:controller="controllers.MatchesController">
   <center>
      <VBox spacing="30.0" BorderPane.alignment="CENTER"><padding><Insets bottom="40.0" left="40.0" right="40.0" top="40.0" /></padding>
         <VBox style="-fx-background-color: #FFFFFF; -fx-background-radius: 20;"><padding><Insets bottom="30" left="30" right="30" top="30" /></padding><effect><DropShadow blurType="GAUSSIAN" radius="19.5"><color><Color opacity="0.08" /></color></DropShadow></effect>
            <Label text="Duellos" textFill="#2b3674"><font><Font name="System Bold" size="20.0" /></font></Label>
            <Separator prefWidth="200.0"><VBox.margin><Insets bottom="20.0" top="15.0" /></VBox.margin></Separator>
            <HBox spacing="15"><VBox.margin><Insets bottom="20" /></VBox.margin>
               <Button prefHeight="35" prefWidth="120" style="-fx-background-color: #E6F4EA; -fx-text-fill: #1E8E3E; -fx-border-radius: 10; -fx-background-radius: 10; -fx-font-weight: bold;" text="Pro">
                  <cursor>
                     <Cursor fx:constant="HAND" />
                  </cursor></Button>
            </HBox>
            <HBox alignment="CENTER_LEFT" style="-fx-background-color: #FCE8E8; -fx-border-color: #D93025; -fx-border-radius: 15; -fx-background-radius: 15;"><padding><Insets bottom="10" left="20" right="10" top="10" /></padding>
               <VBox><Label text="Basketball Field YSS | Max 10 player" textFill="#D93025"><font><Font name="System Bold" size="13" /></font></Label><Label text="B**** j**** S**** | Empty Slot: 4 | Pro" textFill="#D93025" /></VBox>
               <Region HBox.hgrow="ALWAYS" />
               <Button prefHeight="35" prefWidth="100" style="-fx-background-color: #D93025; -fx-text-fill: white; -fx-font-weight: bold; -fx-background-radius: 10;" text="Request">
                  <cursor>
                     <Cursor fx:constant="HAND" />
                  </cursor></Button>
            </HBox>
         </VBox>
      </VBox>
   </center>
</BorderPane>
