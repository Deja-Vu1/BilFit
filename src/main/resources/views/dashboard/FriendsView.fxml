<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.control.Tab?>
<?import javafx.scene.control.TabPane?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>

<VBox spacing="20.0" styleClass="content-card" stylesheets="@../../css/bilfit-exact.css" xmlns="http://javafx.com/javafx/25" xmlns:fx="http://javafx.com/fxml/1" fx:controller="controllers.FriendsController">
   <children>
      <VBox spacing="5.0" stylesheets="@bilfit-exact.css">
         <children>
            <Label styleClass="content-title" stylesheets="@bilfit-exact.css" text="Friends Network" />
         </children>
      </VBox>

      <HBox alignment="CENTER_LEFT" spacing="15.0">
         <children>
            <TextField fx:id="searchField" promptText="Search friends..." styleClass="modern-input" stylesheets="@bilfit-exact.css" HBox.hgrow="ALWAYS" />
            <Button mnemonicParsing="false" onAction="#handleRefresh" styleClass="btn-secondary" stylesheets="@bilfit-exact.css" text="🔄 Refresh" />
            <Button mnemonicParsing="false" onAction="#handleAddFriend" styleClass="btn-success" stylesheets="@bilfit-exact.css" text="+ Add Friend" />
         </children>
         <padding>
            <Insets bottom="10.0" top="10.0" />
         </padding>
      </HBox>

      <TabPane stylesheets="@bilfit-exact.css" tabClosingPolicy="UNAVAILABLE" VBox.vgrow="ALWAYS">
        <tabs>
          <Tab text="My Friends">
               <content>
                  <ScrollPane fitToWidth="true" vbarPolicy="ALWAYS">
                     <content>
                        <TableView fx:id="friendsTable" stylesheets="@bilfit-exact.css">
                          <columns>
                            <TableColumn fx:id="colFriendName" prefWidth="250.0" text="Name" />
                            <TableColumn fx:id="colFriendStatus" prefWidth="150.0" text="Reliability Score" />
                              <TableColumn fx:id="colFriendELO" prefWidth="120.0" text="ELO Rating" />
                              <TableColumn fx:id="colFriendActions" prefWidth="150.0" text=" Last Seen" />
                          </columns>
                           <columnResizePolicy>
                              <TableView fx:constant="CONSTRAINED_RESIZE_POLICY" />
                           </columnResizePolicy>
                        </TableView>
                     </content>
                  </ScrollPane>
               </content>
          </Tab>
          <Tab text="Incoming Requests">
               <content>
                  <ScrollPane fitToWidth="true" hbarPolicy="NEVER" vbarPolicy="ALWAYS">
                     <content>
                        <TableView fx:id="incomingTable" stylesheets="@bilfit-exact.css">
                          <columns>
                            <TableColumn fx:id="colIncomingName" prefWidth="250.0" text="Name" />
                            <TableColumn fx:id="colIncomingStatus" prefWidth="150.0" text="Reliability Score" />
                              <TableColumn fx:id="colIncomingELO" prefWidth="120.0" text="ELO Rating" />
                              <TableColumn fx:id="colIncomingActions" prefWidth="220.0" text="Last Seen" />
                          </columns>
                           <columnResizePolicy>
                              <TableView fx:constant="CONSTRAINED_RESIZE_POLICY" />
                           </columnResizePolicy>
                        </TableView>
                     </content>
                  </ScrollPane>
               </content>
          </Tab>
            <Tab text="Outgoing Requests">
               <content>
                  <ScrollPane fitToWidth="true" vbarPolicy="ALWAYS">
                     <content>
                        <TableView fx:id="outgoingTable" stylesheets="@bilfit-exact.css">
                          <columns>
                            <TableColumn fx:id="colOutgoingName" prefWidth="250.0" text="Name" />
                            <TableColumn fx:id="colOutgoingStatus" prefWidth="150.0" text="Reliability Score" />
                              <TableColumn fx:id="colOutgoingELO" prefWidth="120.0" text="ELO Rating" />
                              <TableColumn fx:id="colOutgoingActions" prefWidth="150.0" text="Last Seen" />
                          </columns>
                           <columnResizePolicy>
                              <TableView fx:constant="CONSTRAINED_RESIZE_POLICY" />
                           </columnResizePolicy>
                        </TableView>
                     </content>
                  </ScrollPane>
               </content>
            </Tab>
        </tabs>
      </TabPane>
   </children>
   <padding>
      <Insets bottom="30.0" left="30.0" right="30.0" top="30.0" />
   </padding>
</VBox>
