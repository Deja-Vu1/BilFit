<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.shape.Circle?>
<?import javafx.scene.text.Font?>

<VBox spacing="30.0" style="-fx-background-color: #F4F7FE;" stylesheets="@bilfit-exact.css" xmlns="http://javafx.com/javafx/19" xmlns:fx="http://javafx.com/fxml/1" fx:controller="controllers.AdminProfileController">
   <padding>
      <Insets bottom="40.0" left="40.0" right="40.0" top="40.0" />
   </padding>
   
   <VBox styleClass="content-card">
      <Label styleClass="content-title" text="Admin Profile">
         <VBox.margin>
            <Insets bottom="20.0" />
         </VBox.margin>
      </Label>
      <HBox alignment="CENTER_LEFT" spacing="30">
         
         <StackPane fx:id="profileImageContainer" onMouseClicked="#handleProfilePictureUpload" style="-fx-cursor: hand;" maxHeight="100.0" maxWidth="100.0">
            <Circle fx:id="profileImageCircle" fill="#E2E8F0" radius="50.0" stroke="#4318FF" strokeType="INSIDE" strokeWidth="3.0" />
            <VBox fx:id="editIconOverlay" alignment="CENTER" style="-fx-background-color: rgba(0,0,0,0.5); -fx-background-radius: 50;" visible="false" maxHeight="100.0" maxWidth="100.0">
               <Label text="✏️" textFill="WHITE">
                  <font><Font size="28.0" /></font>
               </Label>
            </VBox>
         </StackPane>
         
         <VBox spacing="10" alignment="CENTER_LEFT">
            <Label fx:id="nameLabel" text="Yükleniyor..." textFill="#2b3674">
               <font>
                  <Font name="System Bold" size="22.0" />
               </font>
            </Label>
            <HBox spacing="10">
               <Label styleClass="tag-orange" text="👑 System Administrator" />
            </HBox>
         </VBox>
      </HBox>
   </VBox>

   <HBox spacing="20.0" VBox.vgrow="ALWAYS">
      <VBox style="-fx-background-color: #FFFFFF; -fx-background-radius: 20; -fx-border-color: #E2E8F0; -fx-border-radius: 20;" HBox.hgrow="ALWAYS">
         <padding><Insets bottom="30" left="30" right="30" top="30" /></padding>
         <HBox alignment="TOP_RIGHT">
            <Label styleClass="btn-secondary" text="Students" />
         </HBox>
         <Region VBox.vgrow="ALWAYS" />
         <Label fx:id="totalStudentsLabel" text="0" textFill="#4318FF">
            <font><Font name="System Bold" size="40.0" /></font>
         </Label>
         <Label text="Total Students" textFill="#2B3674">
            <font><Font name="System Bold" size="14.0" /></font>
         </Label>
      </VBox>

      <VBox style="-fx-background-color: #FFF4E5; -fx-background-radius: 20;" HBox.hgrow="ALWAYS">
         <padding><Insets bottom="30" left="30" right="30" top="30" /></padding>
         <HBox alignment="TOP_RIGHT">
            <Label style="-fx-background-color: #FFD6A5; -fx-text-fill: #E65C00; -fx-background-radius: 10; -fx-padding: 5 10 5 10; -fx-font-weight: bold; -fx-font-size: 12px;" text="Staff" />
         </HBox>
         <Region VBox.vgrow="ALWAYS" />
         <Label fx:id="totalAdminsLabel" text="0" textFill="#FF9120">
            <font><Font name="System Bold" size="40.0" /></font>
         </Label>
         <Label text="Total Admins" textFill="#FF9120">
            <font><Font name="System Bold" size="14.0" /></font>
         </Label>
      </VBox>

      <VBox style="-fx-background-color: #FCE8E8; -fx-background-radius: 20;" HBox.hgrow="ALWAYS">
         <padding><Insets bottom="30" left="30" right="30" top="30" /></padding>
         <HBox alignment="TOP_RIGHT">
            <Label styleClass="btn-danger" text="Facilities" />
         </HBox>
         <Region VBox.vgrow="ALWAYS" />
         <Label fx:id="totalFacilitiesLabel" text="0" textFill="#D93025">
            <font><Font name="System Bold" size="40.0" /></font>
         </Label>
         <Label text="Total Facilities" textFill="#D93025">
            <font><Font name="System Bold" size="14.0" /></font>
         </Label>
      </VBox>

      <VBox style="-fx-background-color: #E6F4EA; -fx-background-radius: 20;" HBox.hgrow="ALWAYS">
         <padding><Insets bottom="30" left="30" right="30" top="30" /></padding>
         <HBox alignment="TOP_RIGHT">
            <Label styleClass="btn-success" text="Activity" />
         </HBox>
         <Region VBox.vgrow="ALWAYS" />
         <Label fx:id="adminActionsLabel" text="0" textFill="#1E8E3E">
            <font><Font name="System Bold" size="40.0" /></font>
         </Label>
         <Label text="Admin Actions" textFill="#1E8E3E">
            <font><Font name="System Bold" size="14.0" /></font>
         </Label>
      </VBox>
   </HBox>
</VBox>