<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.text.*?>

<VBox spacing="25.0" style="-fx-background-color: #F4F7FE;" stylesheets="@bilfit-exact.css" xmlns="http://javafx.com/javafx/19" xmlns:fx="http://javafx.com/fxml/1" fx:controller="controllers.ELOController">
   <padding>
      <Insets bottom="30.0" left="40.0" right="40.0" top="30.0" />
   </padding>
   
   <VBox styleClass="content-card">
      <HBox alignment="CENTER_LEFT">
         <Label styleClass="content-title" text="Your Reservations" />
         <Region HBox.hgrow="ALWAYS" />
         <Label style="-fx-font-size: 24;" text="🎟️" />
      </HBox>
      <Separator prefWidth="200.0">
         <VBox.margin>
            <Insets bottom="15.0" top="10.0" />
         </VBox.margin>
      </Separator>
      
      <HBox alignment="CENTER_LEFT" style="-fx-border-color: #4318FF; -fx-border-radius: 15; -fx-background-radius: 15; -fx-background-color: #FFFFFF;">
         <padding>
            <Insets bottom="10.0" left="20.0" right="10.0" top="10.0" />
         </padding>
         
         <Label fx:id="activeReservationLabel" text="Loading..." textFill="#2b3674">
            <font>
               <Font name="System Bold" size="13.0" />
            </font>
         </Label>
         <Region HBox.hgrow="ALWAYS" />
         
         <Button onAction="#handleCreateDuello" prefHeight="35.0" prefWidth="130.0" styleClass="btn-success" text="Create A Duello" />
      </HBox>
   </VBox>
   
   <VBox styleClass="content-card" VBox.vgrow="ALWAYS">
      <HBox alignment="CENTER_LEFT">
         <VBox>
            <Label styleClass="content-title" text="Duellos" />
         </VBox>
         <Region HBox.hgrow="ALWAYS" />
         
         <Button onAction="#handleApplyWithCode" prefHeight="35.0" prefWidth="140.0" styleClass="btn-success" text="Apply With Code" />
      </HBox>
      
      <Separator prefWidth="200.0">
         <VBox.margin>
            <Insets bottom="15.0" top="10.0" />
         </VBox.margin>
      </Separator>
      
      <VBox spacing="15">
         <HBox alignment="CENTER_LEFT" style="-fx-background-color: #FCE8E8; -fx-border-color: #D93025; -fx-border-radius: 15; -fx-background-radius: 15;">
            <padding>
               <Insets bottom="10.0" left="20.0" right="10.0" top="10.0" />
            </padding>
            <VBox spacing="5">
               <Label fx:id="duelloMainInfoLabel" text="Loading..." textFill="#D93025">
                  <font>
                     <Font name="System Bold" size="13.0" />
                  </font>
               </Label>
               <Label fx:id="duelloSubInfoLabel" text="Loading..." textFill="#D93025" />
            </VBox>
            <Region HBox.hgrow="ALWAYS" />
            
            <Label style="-fx-font-size: 24;" text="🔥">
               <HBox.margin>
                  <Insets right="15" />
               </HBox.margin>
            </Label>
            
            <Button onAction="#handleRequestDuello" prefHeight="35.0" prefWidth="100.0" style="-fx-background-color: #D93025; -fx-text-fill: #FFFFFF; -fx-font-weight: bold; -fx-background-radius: 10;" text="Request" />
         </HBox>
      </VBox>
   </center>
</BorderPane>
