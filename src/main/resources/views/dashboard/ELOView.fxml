<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.Cursor?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.control.Separator?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.VBox?>


<ScrollPane hbarPolicy="NEVER" stylesheets="@bilfit-exact.css" xmlns="http://javafx.com/javafx/25" xmlns:fx="http://javafx.com/fxml/1" fx:controller="controllers.ELOController">
   <content>
      <VBox prefHeight="585.0" prefWidth="886.0" spacing="25.0" style="-fx-background-color: #F4F7FE;" stylesheets="@bilfit-exact.css">
         <padding>
            <Insets bottom="30.0" left="40.0" right="40.0" top="30.0" />
         </padding>
         
         <VBox styleClass="content-card">
            <HBox alignment="CENTER_LEFT">
               <Label styleClass="content-title" text="Your Reservations" />
               <Region HBox.hgrow="ALWAYS" />
               <Label style="-fx-font-size: 24;" text="🎟️" />
            </HBox>
            <Separator prefWidth="200.0">
               <VBox.margin>
                  <Insets bottom="15.0" top="10.0" />
               </VBox.margin>
            </Separator>
            
            <ScrollPane fitToWidth="true" hbarPolicy="NEVER" prefHeight="130.0" style="-fx-background-color: transparent; -fx-background: transparent;" vbarPolicy="AS_NEEDED">
                <VBox fx:id="reservationsContainer" spacing="15.0">
                    <padding>
                        <Insets right="10.0" />
                    </padding>
                </VBox>
            </ScrollPane>
         </VBox>
      
         <VBox styleClass="content-card">
            <HBox alignment="CENTER_LEFT">
               <Label styleClass="content-title" text="My Duellos" />
               <Region HBox.hgrow="ALWAYS" />
               <Label style="-fx-font-size: 24;" text="⚔️" />
            </HBox>
            <Separator prefWidth="200.0">
               <VBox.margin>
                  <Insets bottom="15.0" top="10.0" />
               </VBox.margin>
            </Separator>
            
            <ScrollPane fitToWidth="true" hbarPolicy="NEVER" prefHeight="130.0" style="-fx-background-color: transparent; -fx-background: transparent;" vbarPolicy="AS_NEEDED">
                <VBox fx:id="myDuellosContainer" spacing="15.0">
                    <padding>
                        <Insets right="10.0" />
                    </padding>
                </VBox>
            </ScrollPane>
         </VBox>
         
         <VBox styleClass="content-card" VBox.vgrow="ALWAYS">
            <HBox alignment="CENTER_LEFT">
               <VBox>
                  <Label styleClass="content-title" text="Available Duellos" />
               </VBox>
               <Region HBox.hgrow="ALWAYS" />
               
               <Button onAction="#handleApplyWithCode" prefHeight="35.0" prefWidth="140.0" styleClass="btn-success" text="Apply With Code">
                  <cursor>
                     <Cursor fx:constant="HAND" />
                  </cursor>
               </Button>
            </HBox>
            
            <Separator prefWidth="200.0">
               <VBox.margin>
                  <Insets bottom="15.0" top="10.0" />
               </VBox.margin>
            </Separator>
            
            <ScrollPane fitToWidth="true" hbarPolicy="NEVER" prefHeight="150.0" style="-fx-background-color: transparent; -fx-background: transparent;" vbarPolicy="AS_NEEDED">
                <VBox fx:id="duellosContainer" spacing="15.0">
                    <padding>
                        <Insets right="10.0" />
                    </padding>
                </VBox>
            </ScrollPane>
         </VBox>
      </VBox>
   </content>
</ScrollPane>
