<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.text.*?>

<VBox spacing="30.0" style="-fx-background-color: #F4F7FE;" stylesheets="@bilfit-exact.css" xmlns="http://javafx.com/javafx/19" xmlns:fx="http://javafx.com/fxml/1" fx:controller="controllers.ReservationController">
   <padding>
      <Insets bottom="40.0" left="40.0" right="40.0" top="40.0" />
   </padding>

   <VBox styleClass="content-card" prefHeight="400.0">
      <HBox alignment="CENTER_LEFT">
         <Label text="Your Reservations" styleClass="content-title"/>
         <Region HBox.hgrow="ALWAYS"/>
         <Label text="🎫" style="-fx-font-size: 24;"/>
      </HBox>
      <Separator prefWidth="200.0">
         <VBox.margin>
            <Insets bottom="20.0" top="15.0" />
         </VBox.margin>
      </Separator>
      
      <ScrollPane fitToWidth="true" style="-fx-background-color: transparent; -fx-background: transparent;" 
                  prefHeight="300.0" hbarPolicy="NEVER" vbarPolicy="AS_NEEDED">
          <VBox fx:id="reservationsContainer" spacing="15.0">
              <padding>
                  <Insets right="10.0" />
              </padding>
          </VBox>
      </ScrollPane>
   </VBox>

   <VBox styleClass="content-card" VBox.vgrow="ALWAYS">
      <HBox alignment="CENTER_LEFT">
         <Label text="Make a New Reservation" styleClass="content-title"/>
         <Region HBox.hgrow="ALWAYS"/>
         <Label text="🛎️" style="-fx-font-size: 24;"/>
      </HBox>
      <Separator prefWidth="200.0">
         <VBox.margin>
            <Insets bottom="20.0" top="15.0" />
         </VBox.margin>
      </Separator>
      
      <HBox spacing="15">
         <VBox.margin>
            <Insets bottom="20"/>
         </VBox.margin>
         <Button fx:id="basketballBtn" prefHeight="40" prefWidth="120" styleClass="btn-secondary" text="Basketball" />
         <Button fx:id="footballBtn" prefHeight="40" prefWidth="120" styleClass="btn-success" text="Football" />
      </HBox>
      
      <GridPane hgap="15" vgap="15">
         <columnConstraints>
            <ColumnConstraints hgrow="ALWAYS" percentWidth="25"/>
            <ColumnConstraints hgrow="ALWAYS" percentWidth="25"/>
            <ColumnConstraints hgrow="ALWAYS" percentWidth="25"/>
            <ColumnConstraints hgrow="ALWAYS" percentWidth="25"/>
         </columnConstraints>
         
         <Button fx:id="slot1Btn" maxWidth="Infinity" prefHeight="40" styleClass="btn-danger" text="8.45 - 9.45" GridPane.columnIndex="0" GridPane.rowIndex="0"/>
         <Button fx:id="slot2Btn" maxWidth="Infinity" prefHeight="40" styleClass="btn-success" text="11.45 - 12.45" GridPane.columnIndex="3" GridPane.rowIndex="0"/>
      </GridPane>
   </VBox>
</VBox>