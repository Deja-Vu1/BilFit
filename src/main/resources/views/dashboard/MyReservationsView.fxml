<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.DatePicker?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.control.Separator?>
<?import javafx.scene.layout.GridPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.VBox?>

<VBox prefHeight="800.0" prefWidth="1000.0" spacing="30.0" style="-fx-background-color: #F4F7FE;" stylesheets="@bilfit-exact.css" xmlns="http://javafx.com/javafx/25" xmlns:fx="http://javafx.com/fxml/1" fx:controller="controllers.ReservationController">
   <padding><Insets bottom="40.0" left="40.0" right="40.0" top="40.0" /></padding>

   <VBox styleClass="content-card" VBox.vgrow="ALWAYS">
      <HBox alignment="CENTER_LEFT">
         <Label styleClass="content-title" text="My Reservations" />
         <Region HBox.hgrow="ALWAYS" />
         <Label style="-fx-font-size: 24;" text="📅" />
      </HBox>
      <Label styleClass="content-subtitle" text="Manage your active and past reservations">
         <VBox.margin><Insets bottom="15" top="5" /></VBox.margin>
      </Label>
      <Separator prefWidth="200.0"><VBox.margin><Insets bottom="20.0" /></VBox.margin></Separator>
      
      <ScrollPane fitToHeight="true" fitToWidth="true" style="-fx-background-color: transparent; -fx-background: transparent; -fx-border-color: transparent;" VBox.vgrow="ALWAYS">
         <VBox fx:id="reservationsContainer" spacing="15">
            <padding><Insets right="15" /></padding>
         </VBox>
      </ScrollPane>
   </VBox>

   <VBox styleClass="content-card">
      <HBox alignment="CENTER_LEFT">
         <Label styleClass="content-title" text="Make a Reservation" />
         <Region HBox.hgrow="ALWAYS" />
         <Label style="-fx-font-size: 24;" text="🛎️" />
      </HBox>
      <Label styleClass="content-subtitle" text="Select a facility, date, and time slot to book your field">
         <VBox.margin><Insets bottom="15" top="5" /></VBox.margin>
      </Label>
      <Separator prefWidth="200.0"><VBox.margin><Insets bottom="20.0" /></VBox.margin></Separator>
      
      <HBox alignment="BOTTOM_LEFT" spacing="20">
         <VBox.margin><Insets bottom="20" /></VBox.margin>
         <VBox spacing="8">
            <Label style="-fx-font-size: 14px;" styleClass="content-title" text="Facility" />
            <ComboBox fx:id="facilityComboBox" prefHeight="40" prefWidth="250" styleClass="modern-input" />
         </VBox>
         <VBox spacing="8">
            <Label style="-fx-font-size: 14px;" styleClass="content-title" text="Date" />
            <DatePicker fx:id="datePicker" prefHeight="40" prefWidth="200" styleClass="modern-input" />
         </VBox>
         <Button fx:id="refreshBtn" prefHeight="40" styleClass="btn-secondary" text="🔄 Refresh">
            <HBox.margin><Insets bottom="2" /></HBox.margin>
         </Button>
      </HBox>

      <Label style="-fx-font-size: 14px;" styleClass="content-title" text="Available Time Slots" />
      <GridPane fx:id="timeSlotGrid" alignment="CENTER_LEFT" hgap="10" vgap="10">
         <VBox.margin><Insets bottom="15" top="10" /></VBox.margin>
      </GridPane>
   </VBox>

</VBox>
