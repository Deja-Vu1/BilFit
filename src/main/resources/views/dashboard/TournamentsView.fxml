<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.control.Separator?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>

<ScrollPane fitToWidth="true" style="-fx-background-color: #F4F7FE;" stylesheets="@bilfit-exact.css" xmlns="http://javafx.com/javafx/17" xmlns:fx="http://javafx.com/fxml/1" fx:controller="controllers.TournamentsController">
   <content>
      <VBox spacing="25.0" style="-fx-background-color: #F4F7FE;">
         <padding>
            <Insets bottom="30.0" left="40.0" right="40.0" top="30.0" />
         </padding>

         <VBox styleClass="content-card" spacing="15.0">
            <HBox alignment="CENTER_LEFT">
               <VBox spacing="5.0">
                  <Label styleClass="content-title" text="Upcoming Tournaments" />
                  <Label styleClass="content-subtitle" text="View and join active tournaments" />
               </VBox>
               <Region HBox.hgrow="ALWAYS" />
               <Button fx:id="applyCodeButton" onAction="#handleApplyWithCode" prefHeight="40.0" styleClass="btn-primary" text="Apply With Code" />
            </HBox>
            <Separator />
            <VBox fx:id="upcomingTournamentsContainer" spacing="10.0" />
         </VBox>

         <VBox fx:id="myTournamentsCard" styleClass="content-card" spacing="15.0" visible="false" managed="false">
            <VBox spacing="5.0">
               <Label styleClass="content-title" text="Your Tournaments" />
               <Label styleClass="content-subtitle" text="Manage the tournaments you are participating in" />
            </VBox>
            <Separator />
            <VBox fx:id="myTournamentsContainer" spacing="10.0" />
         </VBox>

         <VBox styleClass="content-card" spacing="15.0">
            <HBox alignment="CENTER_LEFT" spacing="15.0">
               <VBox spacing="5.0">
                  <Label styleClass="content-title" text="Team Management" />
                  <Label styleClass="content-subtitle" text="Handle incoming and outgoing team requests" />
               </VBox>
               <Region HBox.hgrow="ALWAYS" />
               <HBox spacing="10.0">
                  <Button fx:id="btnIncoming" onAction="#showIncoming" prefHeight="35.0" prefWidth="150.0" styleClass="tab-btn-active" text="Incoming Requests" />
                  <Button fx:id="btnOutgoing" onAction="#showOutgoing" prefHeight="35.0" prefWidth="150.0" styleClass="tab-btn-inactive" text="Outgoing Requests" />
               </HBox>
            </HBox>
            <Separator />
            <StackPane alignment="TOP_LEFT">
               <VBox fx:id="incomingRequestsContainer" spacing="10.0" />
               <VBox fx:id="outgoingRequestsContainer" spacing="10.0" visible="false" managed="false" />
            </StackPane>
         </VBox>

      </VBox>
   </content>
</ScrollPane>