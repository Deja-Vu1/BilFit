         <VBox alignment="CENTER" spacing="10.0"><padding><Insets bottom="10.0" /></padding><Circle fill="#E2E8F0" radius="35.0" stroke="#4318FF" strokeType="INSIDE" strokeWidth="2.0" /><HBox alignment="CENTER" spacing="15.0"><Circle fill="#4318FF" radius="12.0" /><Circle fill="#FF9120" radius="12.0" /></HBox><Separator prefWidth="200.0"><VBox.margin><Insets bottom="10.0" top="10.0" /></VBox.margin></Separator></VBox>
         <VBox spacing="8.0"><padding><Insets left="20.0" right="20.0" /></padding>
