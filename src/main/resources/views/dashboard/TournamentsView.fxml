            <Separator prefWidth="200.0"><VBox.margin><Insets bottom="15.0" top="10.0" /></VBox.margin></Separator>
            <HBox alignment="CENTER_LEFT" style="-fx-border-color: #4318FF; -fx-border-radius: 15; -fx-background-radius: 15; -fx-background-color: #FFFFFF;"><padding><Insets bottom="10.0" left="20.0" right="10.0" top="10.0" /></padding>
               <Label text="Football Tournament   |   25.02.2026 - 20.03.2026   |   Max 10 player" textFill="#2b3674"><font><Font name="System Bold" size="13.0" /></font></Label>
               <Region HBox.hgrow="ALWAYS" />
               <Button prefHeight="35.0" prefWidth="100.0" styleClass="btn-secondary" text="Apply" />
            </HBox>
         </VBox>

         <VBox styleClass="content-card">
            <Label text="Your Tournaments" styleClass="content-title"/>
