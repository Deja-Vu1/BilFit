         </VBox>
      </VBox>
   </left>
   <center>
      <VBox spacing="20.0" BorderPane.alignment="CENTER"><padding><Insets bottom="30.0" left="40.0" right="40.0" top="30.0" /></padding>
         
         <VBox styleClass="content-card">
