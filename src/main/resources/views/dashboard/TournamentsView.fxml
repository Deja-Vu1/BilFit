            <HBox alignment="CENTER_LEFT" style="-fx-border-color: #4318FF; -fx-border-radius: 15; -fx-background-radius: 15; -fx-background-color: #FFFFFF;"><padding><Insets bottom="10.0" left="20.0" right="10.0" top="10.0" /></padding>
               <VBox spacing="5"><Label text="Football Tournament   |   25.02.2026 - 20.03.2026" textFill="#2b3674"><font><Font name="System Bold" size="13.0" /></font></Label><Label text="Access Code: A934C456   |   Empty Slot: 3 Player" styleClass="content-subtitle"/></VBox>
               <Region HBox.hgrow="ALWAYS" />
               <Button prefHeight="35.0" prefWidth="100.0" styleClass="btn-secondary" text="Schedule" />
               <Button prefHeight="35.0" prefWidth="100.0" styleClass="btn-danger" text="Cancel" ><HBox.margin><Insets left="10"/></HBox.margin></Button>
