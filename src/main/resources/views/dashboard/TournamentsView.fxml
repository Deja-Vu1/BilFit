<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.control.Separator?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Font?>

<VBox prefHeight="800.0" prefWidth="1200.0" spacing="20.0" style="-fx-background-color: #F4F7FE;" stylesheets="@bilfit-exact.css" xmlns="http://javafx.com/javafx/25" xmlns:fx="http://javafx.com/fxml/1" fx:controller="controllers.TournamentsController">
   <padding>
      <Insets bottom="30.0" left="40.0" right="40.0" top="30.0" />
   </padding>
   
   <VBox styleClass="content-card">
      <HBox alignment="CENTER_LEFT">
         <Label styleClass="content-title" text="Upcoming Tournaments" />
         <Region HBox.hgrow="ALWAYS" />
         <Button fx:id="applyCodeButton" onAction="#handleApplyWithCode" prefHeight="35.0" prefWidth="140.0" styleClass="btn-success" text="Apply With Code" />
      </HBox>
      <Separator prefWidth="200.0">
         <VBox.margin><Insets bottom="15.0" top="10.0" /></VBox.margin>
      </Separator>
      <ScrollPane fitToHeight="true" fitToWidth="true">
         <content>
            <VBox prefHeight="200.0" prefWidth="100.0">
               <children>
                  <HBox alignment="CENTER_LEFT" style="-fx-border-color: #4318FF; -fx-border-radius: 15; -fx-background-radius: 15; -fx-background-color: #FFFFFF;">
                     <padding>
                        <Insets bottom="10.0" left="20.0" right="10.0" top="10.0" />
                     </padding>
                     <Label text="Football Tournament   |   25.02.2026 - 20.03.2026   |   Max 10 player" textFill="#2b3674">
                        <font>
                           <Font name="System Bold" size="13.0" />
                        </font>
                     </Label>
                     <Region HBox.hgrow="ALWAYS" />
                     <Button fx:id="applyButton" onAction="#handleApplyTournament" prefHeight="35.0" prefWidth="100.0" styleClass="btn-secondary" text="Apply" />
                  </HBox>
               </children>
            </VBox>
         </content>
      </ScrollPane>
   </VBox>

   <VBox fx:id="myTournamentsCard" managed="false" styleClass="content-card" visible="false">
      <Label styleClass="content-title" text="Your Tournaments" />
      <Separator prefWidth="200.0">
         <VBox.margin><Insets bottom="15.0" top="10.0" /></VBox.margin>
      </Separator>
      <HBox alignment="CENTER_LEFT" style="-fx-border-color: #4318FF; -fx-border-radius: 15; -fx-background-radius: 15; -fx-background-color: #FFFFFF;">
         <padding><Insets bottom="10.0" left="20.0" right="10.0" top="10.0" /></padding>
         <VBox spacing="5">
            <Label text="Football Tournament   |   25.02.2026 - 20.03.2026" textFill="#2b3674">
               <font><Font name="System Bold" size="13.0" /></font>
            </Label>
            <Label styleClass="content-subtitle" text="Access Code: 1234   |   Empty Slot: 3 Player" />
         </VBox>
         <Region HBox.hgrow="ALWAYS" />
         <Button onAction="#handleScheduleTournament" prefHeight="35.0" prefWidth="100.0" styleClass="btn-secondary" text="Schedule" />
         <Button fx:id="cancelButton" onAction="#handleCancelTournament" prefHeight="35.0" prefWidth="100.0" styleClass="btn-danger" text="Cancel">
            <HBox.margin><Insets left="10" /></HBox.margin>
         </Button>
      </HBox>
   </VBox>

   <VBox styleClass="content-card" VBox.vgrow="ALWAYS">
      <Label styleClass="content-title" text="Find Partner for Tournaments" />
      <Separator prefWidth="200.0">
         <VBox.margin><Insets bottom="15.0" top="10.0" /></VBox.margin>
      </Separator>
      <ScrollPane fitToHeight="true" fitToWidth="true" prefHeight="299.0" prefWidth="1069.0">
         <content>
            <VBox prefHeight="281.0" prefWidth="1057.0">
               <children>
                  <HBox alignment="CENTER_LEFT" style="-fx-background-color: #FCE8E8; -fx-border-color: #D93025; -fx-border-radius: 15; -fx-background-radius: 15;">
                     <padding>
                        <Insets bottom="10.0" left="20.0" right="10.0" top="10.0" />
                     </padding>
                     <VBox spacing="5">
                        <Label text="Tennis Tournament   |   25.02.2026 - 20.03.2026" textFill="#D93025">
                           <font>
                              <Font name="System Bold" size="13.0" />
                           </font>
                        </Label>
                        <Label text="B**** j**** S**** |   Empty Slot: 4   |   Beginner" textFill="#D93025" />
                     </VBox>
                     <Region HBox.hgrow="ALWAYS" />
                     <Button onAction="#handleRequestPartner" prefHeight="35.0" prefWidth="100.0" style="-fx-background-color: #D93025; -fx-text-fill: #FFFFFF; -fx-font-weight: bold; -fx-background-radius: 10;" text="Request" />
                  </HBox>
               </children>
            </VBox>
         </content>
      </ScrollPane>
   </VBox>
</VBox>
