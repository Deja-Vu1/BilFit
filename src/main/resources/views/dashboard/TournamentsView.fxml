               <VBox spacing="5"><Label text="Tennis Tournament   |   25.02.2026 - 20.03.2026" textFill="#D93025"><font><Font name="System Bold" size="13.0" /></font></Label><Label text="B**** j**** S**** |   Empty Slot: 4   |   Beginner" textFill="#D93025"/></VBox>
               <Region HBox.hgrow="ALWAYS" />
               <Button prefHeight="35.0" prefWidth="100.0" style="-fx-background-color: #D93025; -fx-text-fill: #FFFFFF; -fx-font-weight: bold; -fx-background-radius: 10;" text="Request" />
            </HBox>
