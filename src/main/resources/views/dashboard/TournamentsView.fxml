            <Button alignment="BASELINE_LEFT" prefHeight="45.0" prefWidth="210.0" styleClass="menu-btn" text="    Home" onAction="#loadHome"/>
            <Button alignment="BASELINE_LEFT" prefHeight="45.0" prefWidth="210.0" styleClass="menu-btn, active" text="    Tournaments" />
            <Button alignment="BASELINE_LEFT" prefHeight="45.0" prefWidth="210.0" styleClass="menu-btn" text="    ELO" onAction="#loadELO"/>
            <Button alignment="BASELINE_LEFT" prefHeight="45.0" prefWidth="210.0" styleClass="menu-btn" text="    Reservation" onAction="#loadReservation"/>
         </VBox>
         <Region VBox.vgrow="ALWAYS" />
         <VBox spacing="8.0"><padding><Insets bottom="30.0" left="20.0" right="20.0" /></padding>
            <Button alignment="BASELINE_LEFT" prefHeight="45.0" prefWidth="210.0" styleClass="menu-btn" style="-fx-background-color: #F4F7FE; -fx-background-radius: 10;" text="    Settings" onAction="#loadSettings"/>
