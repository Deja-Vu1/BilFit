<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.control.Separator?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Font?>

<VBox prefHeight="800.0" prefWidth="1200.0" spacing="20.0" style="-fx-background-color: #F4F7FE;" stylesheets="@bilfit-exact.css" xmlns="http://javafx.com/javafx/25" xmlns:fx="http://javafx.com/fxml/1" fx:controller="controllers.AdminTournamentsController">
   <padding>
      <Insets bottom="40.0" left="40.0" right="40.0" top="40.0" />
   </padding>

   <VBox styleClass="content-card" VBox.vgrow="ALWAYS">
      <HBox alignment="CENTER_LEFT">
         <VBox>
            <Label styleClass="content-title" text="Tournament Management" />
            <Label styleClass="content-subtitle" text="Manage the tournaments in the system, create fixtures, and determine the results." />
         </VBox>
         <Region HBox.hgrow="ALWAYS" />
         <Button onAction="#handleCreateTournament" prefHeight="40" prefWidth="200" style="-fx-background-color: #4318FF; -fx-text-fill: white; -fx-font-weight: bold; -fx-background-radius: 10; -fx-cursor: hand;" text="+ Create New Tournament" />
      </HBox>

      <Separator prefWidth="200.0">
         <VBox.margin>
            <Insets bottom="20.0" top="15.0" />
         </VBox.margin>
      </Separator>

      <ScrollPane fitToWidth="true" VBox.vgrow="ALWAYS" style="-fx-background-color: transparent; -fx-control-inner-background: transparent; -fx-background: transparent; -fx-border-color: transparent;">
          <content>
              <VBox fx:id="tournamentsContainer" spacing="15.0">
                  <padding>
                      <Insets bottom="5.0" left="5.0" right="15.0" top="5.0" />
                  </padding>
              </VBox>
          </content>
      </ScrollPane>

      <HBox alignment="CENTER_LEFT" spacing="20.0">
         <VBox.margin>
            <Insets top="20.0" />
         </VBox.margin>
         <Button onAction="#handleBulkDelete" prefHeight="45.0" prefWidth="220.0" style="-fx-background-color: #D93025; -fx-text-fill: white; -fx-font-weight: bold; -fx-background-radius: 12; -fx-cursor: hand;" text="Delete Selected Tournaments" />
      </HBox>
   </VBox>
</VBox>