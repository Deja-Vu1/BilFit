<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.effect.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.paint.*?>
<?import javafx.scene.text.*?>

<VBox spacing="30" style="-fx-background-color: #F4F7FE;" xmlns="http://javafx.com/javafx/19" xmlns:fx="http://javafx.com/fxml/1" fx:controller="controllers.SettingsController">
   <padding>
      <Insets bottom="40" left="40" right="40" top="40" />
   </padding>
   <VBox style="-fx-background-color: #FFFFFF; -fx-background-radius: 20;">
      <padding>
         <Insets bottom="30" left="30" right="30" top="30" />
      </padding>
      <effect>
         <DropShadow blurType="GAUSSIAN" radius="19.5">
            <color>
               <Color opacity="0.08" />
            </color>
         </DropShadow>
      </effect>
      <Label text="Interests" textFill="#2b3674">
         <font>
            <Font name="System Bold" size="20.0" />
         </font>
      </Label>
      <Label text="User's interests are listed below which is editable by user again." textFill="#a3aed0">
         <VBox.margin>
            <Insets bottom="15" top="5" />
         </VBox.margin>
      </Label>
      <HBox spacing="10">
         <VBox.margin>
            <Insets bottom="15" />
         </VBox.margin>
         <Button prefHeight="35" prefWidth="120" style="-fx-background-color: #F4F7FE; -fx-text-fill: #2b3674; -fx-border-radius: 10; -fx-background-radius: 10;" text="🗑 Basketball" />
         <Button prefHeight="35" prefWidth="120" style="-fx-background-color: #F4F7FE; -fx-text-fill: #2b3674; -fx-border-radius: 10; -fx-background-radius: 10;" text="🗑 Football" />
         <Button prefHeight="35" prefWidth="120" style="-fx-background-color: #E6F4EA; -fx-text-fill: #1E8E3E; -fx-border-radius: 10; -fx-background-radius: 10; -fx-font-weight: bold;" text="+ Add Interest" />
      </HBox>
   </VBox>
   <VBox style="-fx-background-color: #FFFFFF; -fx-background-radius: 20;" VBox.vgrow="ALWAYS">
      <padding>
         <Insets bottom="30" left="30" right="30" top="30" />
      </padding>
      <effect>
         <DropShadow blurType="GAUSSIAN" radius="19.5">
            <color>
               <Color opacity="0.08" />
            </color>
         </DropShadow>
      </effect>
      <Label text="User Settings" textFill="#2b3674">
         <font>
            <Font name="System Bold" size="20.0" />
         </font>
      </Label>
      <HBox alignment="CENTER_LEFT" spacing="20">
         <VBox.margin>
            <Insets bottom="15" top="15" />
         </VBox.margin>
         <Label text="Public account" textFill="#2b3674">
            <font>
               <Font name="System Bold" size="14.0" />
            </font>
         </Label>
         <Button prefHeight="25" prefWidth="50" style="-fx-background-color: #1E8E3E; -fx-background-radius: 20;" />
         <Label text="ELO" textFill="#2b3674">
            <font>
               <Font name="System Bold" size="14.0" />
            </font>
            <HBox.margin>
               <Insets left="30" />
            </HBox.margin>
         </Label>
         <Button prefHeight="25" prefWidth="50" style="-fx-background-color: #E2E8F0; -fx-background-radius: 20;" />
      </HBox>
      <HBox alignment="CENTER_LEFT" spacing="10">
         <Label text="Password" textFill="#2b3674">
            <font>
               <Font name="System Bold" size="14.0" />
            </font>
         </Label>
         <TextField style="-fx-background-color: #F4F7FE; -fx-border-color: #E2E8F0; -fx-background-radius: 10; -fx-border-radius: 10; -fx-padding: 10;" />
         <Button prefHeight="35" prefWidth="100" style="-fx-background-color: #E9EDF7; -fx-text-fill: #4318FF; -fx-font-weight: bold; -fx-background-radius: 10;" text="Change" />
      </HBox>
   </VBox>
</VBox>