<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.CheckBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.Separator?>
<?import javafx.scene.control.TextArea?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.effect.DropShadow?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.paint.Color?>
<?import javafx.scene.text.Font?>

<VBox prefHeight="800.0" prefWidth="1200.0" spacing="30.0" style="-fx-background-color: #F4F7FE;" stylesheets="@bilfit-exact.css" xmlns="http://javafx.com/javafx/25" xmlns:fx="http://javafx.com/fxml/1" fx:controller="controllers.AdminHomeController">
   <padding>
      <Insets bottom="40.0" left="40.0" right="40.0" top="40.0" />
   </padding>
   <children>
   
      <VBox styleClass="content-card">
         <Label styleClass="content-title" text="Upcoming Tournaments" />
         <Label styleClass="content-subtitle" text="Tournaments currently active or upcoming in the system">
            <VBox.margin>
               <Insets top="5.0" />
            </VBox.margin>
         </Label>
         <Separator prefWidth="200.0">
            <VBox.margin>
               <Insets bottom="20.0" top="15.0" />
            </VBox.margin>
         </Separator>
         
         <HBox alignment="CENTER_LEFT" style="-fx-border-color: #4318FF; -fx-border-radius: 15; -fx-background-radius: 15; -fx-background-color: #FFFFFF;">
            <padding>
               <Insets bottom="10.0" left="20.0" right="10.0" top="10.0" />
            </padding>
            <Label fx:id="tournament1Label" text="Loading..." textFill="#2b3674">
               <font>
                  <Font name="System Bold" size="13.0" />
               </font>
            </Label>
         </HBox>
         
         <HBox alignment="CENTER_LEFT">
            <VBox.margin>
               <Insets bottom="10.0" top="10.0" />
            </VBox.margin>
            <padding>
               <Insets left="20.0" />
            </padding>
            <Label styleClass="tag-orange" text="⭐ NEW EVENT" />
         </HBox>
         
         <HBox alignment="CENTER_LEFT" style="-fx-border-color: #4318FF; -fx-border-radius: 15; -fx-background-radius: 15; -fx-background-color: #FFFFFF;">
            <padding>
               <Insets bottom="10.0" left="20.0" right="10.0" top="10.0" />
            </padding>
            <Label fx:id="tournament2Label" text="Loading..." textFill="#2b3674">
               <font>
                  <Font name="System Bold" size="13.0" />
               </font>
            </Label>
         </HBox>
      </VBox>

      <VBox style="-fx-background-color: #FFFFFF; -fx-background-radius: 20;" VBox.vgrow="ALWAYS">
         <padding>
            <Insets bottom="30.0" left="40.0" right="40.0" top="30.0" />
         </padding>
         <effect>
            <DropShadow blurType="GAUSSIAN" radius="19.5">
               <color>
                  <Color opacity="0.08" />
               </color>
            </DropShadow>
         </effect>
         <children>
            <Label text="Notification Center" textFill="#2b3674">
               <font>
                  <Font name="System Bold" size="24.0" />
               </font>
            </Label>
            <Label text="Send broadcast announcements or direct notifications to specific students." textFill="#a3aed0">
               <font>
                  <Font size="14.0" />
               </font>
               <VBox.margin>
                  <Insets bottom="25.0" top="5.0" />
               </VBox.margin>
            </Label>
            
            <Label text="Notification Title" textFill="#2b3674">
               <font>
                  <Font name="System Bold" size="14.0" />
               </font>
               <VBox.margin>
                  <Insets bottom="5.0" />
               </VBox.margin>
            </Label>
            <TextField fx:id="titleField" prefHeight="40.0" promptText="Ex: Indoor Sports Hall Maintenance" style="-fx-background-color: #F4F7FE; -fx-border-color: #E2E8F0; -fx-border-radius: 10; -fx-background-radius: 10; -fx-padding: 10;">
               <VBox.margin>
                  <Insets bottom="20.0" />
               </VBox.margin>
            </TextField>
            
            <Label text="Notification Message" textFill="#2b3674">
               <font>
                  <Font name="System Bold" size="14.0" />
               </font>
               <VBox.margin>
                  <Insets bottom="5.0" />
               </VBox.margin>
            </Label>
            <TextArea fx:id="messageArea" prefHeight="100.0" promptText="Write your message here..." style="-fx-background-color: #F4F7FE; -fx-border-color: #E2E8F0; -fx-border-radius: 10; -fx-background-radius: 10; -fx-padding: 5;" wrapText="true">
               <VBox.margin>
                  <Insets bottom="20.0" />
               </VBox.margin>
            </TextArea>
            
            <CheckBox fx:id="broadcastCheckBox" mnemonicParsing="false" text="Send to Everyone (Broadcast)" textFill="#2b3674">
               <font>
                  <Font name="System Bold" size="14.0" />
               </font>
               <VBox.margin>
                  <Insets bottom="15.0" />
               </VBox.margin>
            </CheckBox>
            
            <Label text="Target Email(s)" textFill="#2b3674">
               <font>
                  <Font name="System Bold" size="14.0" />
               </font>
               <VBox.margin>
                  <Insets bottom="5.0" />
               </VBox.margin>
            </Label>
            <TextArea fx:id="emailsArea" prefHeight="80.0" promptText="Ex: ali@ug.bilkent.edu.tr, veli@ug.bilkent.edu.tr (Separate with commas)" style="-fx-background-color: #F4F7FE; -fx-border-color: #E2E8F0; -fx-border-radius: 10; -fx-background-radius: 10; -fx-padding: 5;" wrapText="true">
               <VBox.margin>
                  <Insets bottom="25.0" />
               </VBox.margin>
            </TextArea>
            
            <Button fx:id="sendBtn" mnemonicParsing="false" onAction="#handleSendNotification" prefHeight="45.0" prefWidth="200.0" style="-fx-background-color: #4318FF; -fx-text-fill: #FFFFFF; -fx-font-weight: bold; -fx-background-radius: 10; -fx-cursor: hand;" text="Send Notification">
               <font>
                  <Font size="15.0" />
               </font>
            </Button>
         </children>
      </VBox>
   </children>
</VBox>