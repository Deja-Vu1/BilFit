<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>

<BorderPane prefHeight="800.0" prefWidth="1200.0" style="-fx-background-color: #F4F7FE;" stylesheets="@bilfit-exact.css" xmlns="http://javafx.com/javafx/25" xmlns:fx="http://javafx.com/fxml/1" fx:controller="controllers.AdminStudentsController">
   <center>
      <VBox spacing="30"><padding><Insets bottom="40" left="40" right="40" top="40" /></padding>
         <VBox prefWidth="1120.0" styleClass="content-card">
            <Label styleClass="content-title" text="Penalty Points" />
            <HBox alignment="CENTER_LEFT" spacing="20"><VBox.margin><Insets bottom="20" top="20" /></VBox.margin>
               <TextField promptText="User Email" styleClass="modern-input" />
               <Label text="or" textFill="#2b3674" />
               <TextField promptText="Student ID" styleClass="modern-input" />
               <TextField prefWidth="60" promptText="15" style="-fx-background-color: #FCE8E8; -fx-text-fill: #D93025; -fx-padding: 10; -fx-background-radius: 10;" />
               <Button prefHeight="35" prefWidth="180" styleClass="btn-success" text="+ Give Penalty Points" />
            </HBox>
         </VBox>
      </VBox>
   </center>
</BorderPane>
